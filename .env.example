# ============================================================
#  OstraClaw — Variáveis de Ambiente
#  ATENÇÃO: Nunca commitar este arquivo com valores reais!
#  Copie para .env e preencha os valores.
# ============================================================

# ── Banco de Dados ─────────────────────────────────────────
POSTGRES_DB=ostraclaw
POSTGRES_USER=ostraclaw
POSTGRES_PASSWORD=CHANGE_ME_STRONG_PASSWORD
DATABASE_URL=postgresql://ostraclaw:CHANGE_ME_STRONG_PASSWORD@ostraclaw_db:5432/ostraclaw

# ── LLM Local ─────────────────────────────────────────────
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=llama3.2:3b
# Alternativa: gemma3:4b, mistral:7b, phi4:14b

# ── Alertas — Telegram ─────────────────────────────────────
TELEGRAM_BOT_TOKEN=SEU_TOKEN_AQUI
TELEGRAM_CHAT_ID=SEU_CHAT_ID_AQUI

# ── Alertas — Slack ────────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/SEU/WEBHOOK/AQUI

# ── Configurações do Agente ────────────────────────────────
CHECK_INTERVAL_SECONDS=10
MAX_FILE_SIZE_MB=50
QUARANTINE_ENABLED=true

# ── Identificação da Imprensa Oficial ─────────────────────
# Metadados esperados do software de criação legítimo
OFFICIAL_CREATOR_PATTERNS=["Acrobat", "PMRO", "Prefeitura", "Diario Oficial", "Diário Oficial"]
OFFICIAL_PRODUCER_PATTERNS=["Adobe", "Acrobat", "PDFCreator", "gs"]

# ── Log Level ─────────────────────────────────────────────
LOG_LEVEL=INFO
